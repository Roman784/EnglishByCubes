    m_Modifications:
    - target: {fileID: 1962036687159115250, guid: 1fb6dae9d5389c0409ae9fec8bb7632f, type: 3}
      propertyPath: m_text
      value: "<b><size=52>\u041E\u0442\u043A\u0440\u044B\u0442\u044B\u0435 \u0432\u043E\u043F\u0440\u043E\u0441\u044B</size></b>\r\n\u0412\u043E\u043F\u0440\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
        \u0441\u043B\u043E\u0432\u0430\u043C\u0438 \u0437\u0434\u0435\u0441\u044C
        \u043C\u043E\u0433\u0443\u0442 \u0431\u044B\u0442\u044C <color=#1EAEE7>WHO</color>
        - \u0434\u043B\u044F \u043E\u0434\u0443\u0448\u0435\u0432\u043B\u0451\u043D\u043D\u043E\u0433\u043E
        \u0441\u0443\u0431\u044A\u0435\u043A\u0442\u0430 \u0438 <color=#1EAEE7>WHAT</color>
        - \u0434\u043B\u044F \u043D\u0435\u043E\u0434\u0443\u0448\u0435\u0432\u043B\u0451\u043D\u043D\u043E\u0433\u043E
        \u043F\u043E\u0434\u043B\u0435\u0436\u0430\u0449\u0435\u0433\u043E.\r\n\r\n\u0421\u0442\u0440\u043E\u044F\u0442\u0441\u044F
        \u0442\u0430\u043A\u0438\u0435 \u0432\u043E\u043F\u0440\u043E\u0441\u044B
        \u0431\u0435\u0437 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0438
        \u0441\u043B\u043E\u0432, \u0441\u043B\u0435\u0434\u0443\u044F \u043F\u0440\u044F\u043C\u043E\u043C\u0443
        \u043F\u043E\u0440\u044F\u0434\u043A\u0443 \u043F\u043E \u0444\u043E\u0440\u043C\u0443\u043B\u0435:\r\n\r\n<b><align=center>WHO/WHAT
        \u2013 BE \u2013 THERE/HERE?\r\n[\u0427\u0442\u043E \u0442\u0430\u043C? \u041A\u0442\u043E
        \u0442\u0430\u043C?]</align></b>\r\n\r\n\u0412\u044B\u0431\u043E\u0440 \u0444\u043E\u0440\u043C\u044B
        <color=#1EAEE7>IS/WAS</color> \u0438\u043B\u0438 <color=#1EAEE7>ARE/WERE</color>
        \u0437\u0430\u0432\u0438\u0441\u0438\u0442 \u043E\u0442 \u0447\u0438\u0441\u043B\u0430
        \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E,
        \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0433\u043E \u0438\u043B\u0438
        \u043F\u0440\u043E\u0448\u0435\u0434\u0448\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438."
      objectReference: {fileID: 0}
