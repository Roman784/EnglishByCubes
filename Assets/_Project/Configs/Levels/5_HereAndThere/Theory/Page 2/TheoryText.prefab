    m_Modifications:
    - target: {fileID: 1962036687159115250, guid: 1fb6dae9d5389c0409ae9fec8bb7632f, type: 3}
      propertyPath: m_text
      value: "<b><size=52>\u0423\u0442\u0432\u0435\u0440\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
        \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u0438</size></b>\r\n\u0421\u0442\u0440\u043E\u044F\u0442\u0441\u044F
        \u043F\u043E \u0444\u043E\u0440\u043C\u0443\u043B\u0435:\r\n\r\n<b><align=center>T/HERE
        \u2013 BE \u2013 O</align></b>\r\n\u0413\u0434\u0435: \r\n<margin=2em><color=#1EAEE7>THERE</color>
        \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0438\u0442\u0441\u044F \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0438\u0442\u0441\u044F
        \u201C\u0442\u0430\u043C, \u0442\u0443\u0434\u0430\u201D;\r\n<color=#1EAEE7>HERE</color>
        \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0438\u0442\u0441\u044F \u201C\u0432\u043E\u0442,
        \u0437\u0434\u0435\u0441\u044C, \u0441\u044E\u0434\u0430\u201D;\r\n\r\n<color=#1EAEE7>IS/WAS</color>
        \u0441\u0442\u043E\u0438\u0442 \u043F\u0435\u0440\u0435\u0434 \u043E\u0434\u043D\u0438\u043C
        \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u043E\u043C;\r\n<color=#1EAEE7>ARE/WERE</color>
        \u0441\u0442\u043E\u0438\u0442 \u043F\u0435\u0440\u0435\u0434 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E\u043C;</margin>\r\n\r\n\u041E\u0431\u044A\u0435\u043A\u0442\u044B
        \u0437\u0434\u0435\u0441\u044C:\r\n<margin=2em>\u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
        \u0432 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
        \u0447\u0438\u0441\u043B\u0435 \u0441 \u0430\u0440\u0442\u0438\u043A\u043B\u0435\u043C
        <color=#1EAEE7>A</color>,\r\n\u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
        \u0432 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
        \u0447\u0438\u0441\u043B\u0435 \u0431\u0435\u0437 \u0430\u0440\u0442\u0438\u043A\u043B\u044F,\r\n\u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
        \u0432\u043E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
        \u0447\u0438\u0441\u043B\u0435 \u0431\u0435\u0437 \u0430\u0440\u0442\u0438\u043A\u043B\u044F,\r\n\u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
        \u0441\u043E \u0441\u043B\u043E\u0432\u0430\u043C\u0438:\r\n<margin=3em><color=#1EAEE7>SOME</color>
        \u201C\u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0439, \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E,\u201D\r\n<color=#1EAEE7>ANY</color>
        \u201C\u043A\u0430\u043A\u0438\u0435-\u043B\u0438\u0431\u043E, \u0441\u043A\u043E\u043B\u044C\u043A\u043E-\u043D\u0438\u0431\u0443\u0434\u044C\u201D,
        \r\n<color=#1EAEE7>NO</color> \u201C\u043D\u0438\u043A\u0430\u043A\u0438\u0435,
        \u043D\u0438\u0441\u043A\u043E\u043B\u044C\u043A\u043E\u201D.</margin>"
