    - target: {fileID: 1962036687159115250, guid: 1fb6dae9d5389c0409ae9fec8bb7632f, type: 3}
      propertyPath: m_text
      value: "<b><size=52>\u041E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
        \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u0438 \u043C\u0435\u0441\u0442\u0430</size></b>\r\n\u0412
        \u043E\u0442\u0440\u0438\u0446\u0430\u043D\u0438\u0438 \u043D\u0430\u043B\u0438\u0447\u0438\u044F
        \u0447\u0435\u0433\u043E-\u043B\u0438\u0431\u043E \u043C\u043E\u0433\u0443\u0442
        \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C\u0441\u044F
        \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
        \u0447\u0430\u0441\u0442\u0438\u0446\u044B:\r\n<color=#1EAEE7>NOT A</color>
        (\u0441 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
        \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u043E\u043C)\r\n<color=#1EAEE7>NOT
        ANY</color> (\u0441 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E\u043C
        \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u043E\u0432)\r\n<color=#1EAEE7>NO</color>
        (\u0441 \u0442\u0435\u043C \u0438 \u0434\u0440\u0443\u0433\u0438\u043C, \u043D\u043E
        \u0441 \u0431\u043E\u043B\u044C\u0448\u0438\u043C \u0430\u043A\u0446\u0435\u043D\u0442\u043E\u043C)\r\n\r\n\u041F\u0440\u0438\u043C\u0435\u0440\u044B:<margin=2em>\r\n\u2022
        There is a book. \u2013 There is not a book.\r\n\u2022 There are some apples.
        \u2013 There are not any apples.\r\n\u2022 There were some books. \u2013
        There are no books.\r\n\u2022 There was an apple. \u2013 There is no apple.\r\n</margin>"
      objectReference: {fileID: 0}
