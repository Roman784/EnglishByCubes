    m_Modifications:
    - target: {fileID: 1962036687159115250, guid: 1fb6dae9d5389c0409ae9fec8bb7632f, type: 3}
      propertyPath: m_text
      value: "<b><size=52>\u0417\u0430\u043A\u0440\u044B\u0442\u044B\u0435 \u0432\u043E\u043F\u0440\u043E\u0441\u044B</size></b>\r\n\u0417\u0430\u043A\u0440\u044B\u0442\u044B\u0435
        \u0432\u043E\u043F\u0440\u043E\u0441\u044B \u0441\u0442\u0440\u043E\u044F\u0442\u0441\u044F
        \u0447\u0435\u0440\u0435\u0437 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0443
        \u043F\u0435\u0440\u0432\u044B\u0445 \u0434\u0432\u0443\u0445 \u0441\u043B\u043E\u0432
        \u043C\u0435\u0441\u0442\u0430\u043C\u0438: IS THERE/ ARE THERE?\r\n\r\n\u0412\u043C\u0435\u0441\u0442\u0435
        \u0441 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
        \u0432 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
        \u0447\u0438\u0441\u043B\u0435 \u0432 \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u0445
        \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442 \u0430\u0440\u0442\u0438\u043A\u043B\u044C
        <color=#1EAEE7>A</color>, \u0430 \u0432\u043C\u0435\u0441\u0442\u0435 \u0441
        \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
        \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
        \u0447\u0438\u0441\u043B\u0430 - \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435
        \u0441\u043B\u043E\u0432\u043E <color=#1EAEE7>ANY</color>.\r\n\r\n\u041A\u0440\u0430\u0442\u043A\u0438\u0435
        \u043E\u0442\u0432\u0435\u0442\u044B \u0434\u043B\u044F \u0432\u043E\u043F\u0440\u043E\u0441\u0430
        - \u0434\u0443\u0431\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
        \u043F\u043E\u0434\u043B\u0435\u0436\u0430\u0449\u0435\u0433\u043E \u0438
        \u0444\u043E\u0440\u043C\u044B \u0433\u043B\u0430\u0433\u043E\u043B\u0430
        <color=#1EAEE7>BE</color>\r\n\r\n\u0428\u0430\u0431\u043B\u043E\u043D \u0432\u043E\u043F\u0440\u043E\u0441\u0430
        \u043A \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044E:\r\n<b><align=center>BE
        \u2013 THERE \u2013 A/ANY \u2013 OBJECT?</align></b>\r\n\r\n\u0428\u0430\u0431\u043B\u043E\u043D
        \u043A\u0440\u0430\u0442\u043A\u043E\u0433\u043E \u043E\u0442\u0432\u0435\u0442\u0430:\r\n<b><align=center>YES,
        \u2013 THERE \u2013 BE</align></b>\r\n<b><align=center>NO, \u2013 THERE \u2013
        BE NOT</align></b>\r\n\r\n\u041F\u0440\u0438\u043C\u0435\u0440\u044B:<margin=2em>\r\n\u2022
        Is there a photo? \u2013 Yes, there is.\r\n\u2022 Are there any apples? \u2013
        No, there are not.\r\n</margin>"
      objectReference: {fileID: 0}
