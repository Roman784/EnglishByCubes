    - target: {fileID: 1962036687159115250, guid: 1fb6dae9d5389c0409ae9fec8bb7632f, type: 3}
      propertyPath: m_text
      value: "<b><size=52>\u0421\u0443\u0431\u044A\u0435\u043A\u0442\u043D\u044B\u0435
        \u0432\u043E\u043F\u0440\u043E\u0441\u044B</size></b>\r\n\u0428\u0430\u0431\u043B\u043E\u043D
        \u0441\u0443\u0431\u044A\u0435\u043A\u0442\u043D\u043E\u0433\u043E \u0432\u043E\u043F\u0440\u043E\u0441\u0430:\r\n<b><align=center>WHO/WHAT
        \u2013 BE \u2013 THERE/HERE?</align></b>\r\n\r\n\u041F\u0440\u0438\u043C\u0435\u0440\u044B:<margin=2em>\r\n\u2022
        What is there? \u2013 The photo is there.\r\n\u2022 What is there? \u2013
        The apples are there.\r\n\u2022 Who was here? \u2013 Ivan was here.\r\n\u2022
        Who were here? \u2013 The students were here.\r\n</margin>\r\n\r\n\u0415\u0441\u043B\u0438
        \u043D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441 <color=#1EAEE7>Where is/are
        \u2026? [\u0433\u0434\u0435\u2026]</color> \u0442\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F
        \u043F\u043E\u0434\u0430\u0442\u044C \u0447\u0442\u043E-\u043B\u0438\u0431\u043E
        \u0432 \u0440\u0443\u043A\u0438, \u0442\u043E \u043E\u0442\u0432\u0435\u0442\u043E\u043C
        \u0431\u0443\u0434\u0435\u0442 <color=#1EAEE7>Here you are [\u0432\u043E\u0442,
        \u044D\u0442\u043E \u0432\u0430\u043C].</color> \u0421\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0430
        \u043E\u0442\u0432\u0435\u0442\u0430 \u043D\u0435 \u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F.\r\n\r\n\u041F\u0440\u0438\u043C\u0435\u0440\u044B:<margin=2em>\r\n\u2022
        Where are the apples? \u2013 Here you are.\r\n\u2022 Where is the book? \u2013
        Here you are.\r\n</margin>\r\n"
      objectReference: {fileID: 0}
