  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 0
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Grammar Cubes \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u0435\u0442
    \u0433\u0440\u0430\u043C\u043C\u0430\u0442\u0438\u043A\u0443 \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430 \u0432 \u0438\u0433\u0440\u043E\u0432\u043E\u0439
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u043E\u0440. \u0412\u044B
    \u0441\u043E\u0431\u0438\u0440\u0430\u0435\u0442\u0435 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u044F,
    \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u0432\u043B\u044F\u044F \u0438 \u043F\u0440\u043E\u043A\u0440\u0443\u0447\u0438\u0432\u0430\u044F
    \u043A\u0443\u0431\u0438\u043A\u0438: \u043A\u0430\u0436\u0434\u0430\u044F \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u044F
    \u0441\u043B\u043E\u0432 \u043D\u0430 \u0441\u0432\u043E\u0451\u043C \u043A\u0443\u0431\u0438\u043A\u0435,
    \u043A\u0430\u0436\u0434\u044B\u0439 \u043A\u0443\u0431\u0438\u043A - \u043D\u0430
    \u0441\u0432\u043E\u0451\u043C \u043C\u0435\u0441\u0442\u0435. \u0412\u044B \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u0435\u0442\u0435
    \u0434\u0443\u043C\u0430\u0442\u044C \u043E \u043F\u043E\u0440\u044F\u0434\u043A\u0435
    \u0441\u043B\u043E\u0432 \u0438 \u043D\u0430\u0447\u043D\u0451\u0442\u0435 \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C
    \u0435\u0433\u043E.\n\r\n\u041F\u0435\u0440\u0432\u044B\u0439 \u043A\u0443\u0440\u0441
    \u043F\u043E\u0441\u0432\u044F\u0449\u0451\u043D \u0433\u043B\u0430\u0433\u043E\u043B\u0443 
    to be.\n\r\n\u041F\u043E \u043C\u0435\u0440\u0435 \u043F\u0440\u043E\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F,
    \u0432\u0430\u043C \u0431\u0443\u0434\u0443\u0442 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0442\u044C\u0441\u044F
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u044B \u0431\u0440\u0438\u0442\u0430\u043D\u0441\u043A\u043E\u0439
    \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u044B \u0441 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u043C\u0438
    \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u043C\u0438 \u043E \u043D\u0435\u0439."
